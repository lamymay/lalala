<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/dialog_tile_bg_selected" />
            <stroke
                android:width="2dp"
                android:color="@color/dialog_tile_stroke_selected" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/dialog_tile_bg" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
